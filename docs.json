{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "QwixAI",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ]
  },
  "logo": "/logo/dark.svg",
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Homepage",
      "href": "https://qwix.chat"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/qwixai",
      "github": "https://github.com/qwixai"
    }
  },
  "background": {
    "decoration": "grid"
  },
  "appearance": {
    "default": "dark"
  },
  "fonts": {
    "family": "Poppins"
  },
  "api": {
    "playground": {
      "display": "interactive"
    }
  }
}
