{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "QwixAI",
  "colors": {
    "primary": "#7C3AED",
    "light": "#A78BFA",
    "dark": "#5B21B6"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "API reference",
        "pages": [
          "api-reference/introduction",
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Homepage",
      "href": "https://qwix.chat"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/qwixai",
      "github": "https://github.com/qwixai"
    }
  },
  "background": {
    "decoration": "grid"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "api": {
    "playground": {
      "display": "interactive"
    }
  },
  "banner": {
    "dismissible": false
  }
}
