{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "QwixAI",
  "colors": {
    "primary": "#7C3AED",
    "light": "#A78BFA",
    "dark": "#5B21B6"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "API Reference",
        "pages": [
          "api-reference/introduction",
          {
            "group": "User",
            "pages": [
              "api-reference/user/get-profile",
              "api-reference/user/update-profile"
            ]
          },
          {
            "group": "Conversations",
            "pages": [
              "api-reference/conversations/list-conversations",
              "api-reference/conversations/create-conversation",
              {
                "group": "Message",
                "expanded": true,
                "pages": [
                  "api-reference/conversations/message/list-messages",
                  "api-reference/conversations/message/send-user-message"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "openapi": "/api-reference/openapi.json",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Homepage",
      "href": "https://qwix.chat"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/qwixai",
      "github": "https://github.com/qwixai"
    }
  },
  "background": {
    "decoration": "grid"
  },
  "appearance": {
    "default": "dark"
  },
  "api": {
    "playground": {
      "display": "interactive"
    },
    "openapi": "api-reference/openapi.json"
  },
  "thumbnails": {
    "appearance": "dark"
  }
}
